pipeline {
    agent any

    stages {
        stage('Build Image') {
            steps {
                script {
                    // Build the Docker image from the Dockerfile in the current directory
                    docker.build("ryanb6040/midterm-project-rb:latest")
                }
            }
        }
        
        stage('Run Container') {
            steps {
                script {
                    // Run a container from the built image
                    docker.image("ryanb6040/midterm-project-rb:latest").run('-p 3000:3000 -t')
                }
            }
        }

        stage('Push Image to Docker Hub') {
            steps {
                script {
                    // Use withRegistry to push the image to Docker Hub
                    docker.withRegistry('https://registry.hub.docker.com/', '5ce9a382-b520-4361-b730-b27b87e719ef') {
                        docker.image("ryanb6040/midterm-project-rb:latest").push()
                    }
                }
            }
        }
    }

}











